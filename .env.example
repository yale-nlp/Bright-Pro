# OpenAI direct (used by GPT-5 judge and gpt-5-mini-08-07 agent)
OPENAI_API_KEY=

# Optional: Azure OpenAI (used as a fallback when OPENAI_API_KEY is unset)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=

# HuggingFace token (required for the gated google/embeddinggemma-300m repo)
HF_TOKEN=

# Optional: override the judge model (default: gpt-5)
# JUDGE_DEPLOYMENT=gpt-5

# Optional: point at a local mirror of yale-nlp/Bright-Pro for offline runs
# Layout: <root>/{examples,documents,aspects}/<task>.json
# BRIGHT_PRO_DATA_ROOT=
